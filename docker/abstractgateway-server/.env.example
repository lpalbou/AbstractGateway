# Gateway user-auth is the default container mode. On first start the
# entrypoint creates default/admin and writes its token to:
#   <mounted runtime>/auth/bootstrap-admin-token
ABSTRACTGATEWAY_USER_AUTH=1
ABSTRACTGATEWAY_BOOTSTRAP_ADMIN=1
# Set to 1 for local demos only; production logs should not contain raw tokens.
ABSTRACTGATEWAY_BOOTSTRAP_PRINT_TOKEN=0
# Optional fixed bootstrap token. Leave empty to generate one.
ABSTRACTGATEWAY_BOOTSTRAP_ADMIN_TOKEN=

# Optional legacy shared Gateway admin token for compatibility/bootstrap APIs.
# Browser apps should sign in with a Gateway user token instead.
ABSTRACTGATEWAY_AUTH_TOKEN=

# Local bind. Keep loopback unless a reverse proxy/TLS layer handles public access.
ABSTRACTGATEWAY_PORT=8080
ABSTRACTGATEWAY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Gateway defaults for bundles that omit provider/model.
ABSTRACTGATEWAY_PROVIDER=openai-compatible
ABSTRACTGATEWAY_MODEL=your-model
ABSTRACTGATEWAY_TOOL_MODE=approval

# Durable storage: file is simplest; sqlite is better for larger installations.
ABSTRACTGATEWAY_STORE_BACKEND=file
# ABSTRACTGATEWAY_DB_PATH=/data/gateway/gateway.sqlite3

# KG memory backend for memory_kg_* workflows and /kg/query.
ABSTRACTGATEWAY_MEMORY_STORE_BACKEND=lancedb
# ABSTRACTGATEWAY_MEMORY_STORE_PATH=/data/gateway/abstractmemory/kg

# Optional standalone AbstractCore server for dynamic Voice/Vision catalog proxying.
ABSTRACTGATEWAY_ABSTRACTCORE_SERVER_BASE_URL=
ABSTRACTGATEWAY_ABSTRACTCORE_SERVER_AUTH_TOKEN=
ABSTRACTGATEWAY_CORE_CATALOG_TIMEOUT_S=3.0

# Host directory containing *.flow bundles. Relative paths are resolved from compose.yml.
ABSTRACTGATEWAY_HOST_FLOWS_DIR=../../flows/bundles

# Hosted/commercial provider keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AbstractGateway
PORTKEY_API_KEY=
PORTKEY_CONFIG=

# OpenAI-compatible local/remote text endpoints.
# For native macOS MLX, keep LM Studio/Ollama on the host and use
# http://model-runner.docker.internal/engines/v1, http://host.docker.internal:1234/v1,
# or http://host.docker.internal:11434/v1.
# LM Studio/Ollama text endpoints are not assumed to expose image generation.
OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_COMPATIBLE_API_KEY=
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434
VLLM_BASE_URL=

# AbstractVision plugin (OpenAI image endpoint by default).
# Use ABSTRACTVISION_BACKEND=diffusers or sdcpp only in custom images with those local deps installed.
ABSTRACTVISION_BACKEND=openai
ABSTRACTVISION_BASE_URL=https://api.openai.com/v1
ABSTRACTVISION_API_KEY=
ABSTRACTVISION_MODEL_ID=gpt-image-1
# Optional non-standard video endpoint paths on compatible servers.
ABSTRACTVISION_TEXT_TO_VIDEO_PATH=
ABSTRACTVISION_IMAGE_TO_VIDEO_PATH=

# AbstractVoice plugin (TTS/STT). The server image defaults to OpenAI remote audio.
ABSTRACTVOICE_LANGUAGE=en
ABSTRACTVOICE_ALLOW_DOWNLOADS=1
ABSTRACTVOICE_TTS_ENGINE=openai
ABSTRACTVOICE_STT_ENGINE=openai
ABSTRACTVOICE_TTS_MODEL=
ABSTRACTVOICE_STT_MODEL=
ABSTRACTVOICE_REMOTE_BASE_URL=
ABSTRACTVOICE_REMOTE_API_KEY=
ABSTRACTVOICE_REMOTE_TIMEOUT_S=

# Local-source builds for unreleased checkouts:
# ABSTRACTGATEWAY_INSTALL_MODE=local
# ABSTRACTGATEWAY_VERSION=0.2.23
# ABSTRACTGATEWAY_IMAGE_TAG=0.2.23-local
# ABSTRACTGATEWAY_EXTRAS=

# NVIDIA full image/local build overlay:
# ABSTRACTGATEWAY_NVIDIA_IMAGE_TAG=0.2.23-gpu
# ABSTRACTGATEWAY_EXTRAS=gpu
# ABSTRACTVISION_BACKEND=diffusers
# ABSTRACTVISION_DIFFUSERS_DEVICE=cuda
# ABSTRACTVISION_DIFFUSERS_ALLOW_DOWNLOAD=0
